<!DOCTYPE html>
<html>

<head>

    <title>Landing Page</title>

    <style>

        body{
            margin:0;
            padding:0;
            font-family:Arial;
            background:linear-gradient(to right,#ff9a9e,#fad0c4,#fbc2eb);
        }

        .header{
            background:#ff4d6d;
            color:white;
            text-align:center;
            padding:50px;
        }

        .section{
            background:white;
            width:70%;
            margin:auto;
            margin-top:40px;
            padding:40px;
            border-radius:20px;
            text-align:center;
            box-shadow:0px 5px 15px gray;
        }

        h1{
            color:yellow;
            font-size:50px;
        }

        h2{
            color:#6a0dad;
            font-size:35px;
        }

        p{
            color:#ff1493;
            font-size:25px;
        }

        button{
            background:#6a0dad;
            color:white;
            border:none;
            padding:15px 30px;
            font-size:22px;
            border-radius:15px;
        }

        .footer{
            background:#ff4d6d;
            color:white;
            text-align:center;
            padding:20px;
            margin-top:50px;
            font-size:20px;
        }

    </style>

</head>

<body>

    <div class="header">

        <h1>Welcome to My Landing Page</h1>

        <p>Learn Web Development Easily</p>

    </div>

    <div class="section">

        <h2>About This Page</h2>

        <p>
            This is a simple and colorful landing page created using HTML and CSS.
        </p>

        <button>Get Started</button>

    </div>

    <div class="footer">

        <p>Created by M.Elaveni</p>

    </div>

</body>

</html>